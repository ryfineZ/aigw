PORT=8327
IFLOW_BASE_URL=https://apis.iflow.cn/v1

# 二选一：
IFLOW_API_KEY=
# IFLOW_API_KEYS=key1,key2,key3

DEFAULT_MODEL=glm-5
# IFLOW_MODELS=glm-5,GLM-4.7

IFLOW_ENABLE_SIGNATURE=true

PROXY_REQUEST_TIMEOUT_MS=180000
PROXY_STREAM_HEARTBEAT_MS=15000
STREAM_EMIT_HEARTBEAT_COMMENTS=true
PROXY_MAX_BODY_BYTES=26214400

LOG_REQUEST_HEADERS=false
LOG_RESPONSE_HEADERS=false

# 多模态桥接（非视觉模型收到图片时，先用视觉模型提取描述再替换）
MM_ENABLED=false
MM_EXTRACTOR_MODEL=qwen3-vl-plus
MM_MAX_IMAGES=4
MM_TIMEOUT_MS=12000
MM_CONTEXT_MESSAGES=6
MM_MAX_TOKENS=1024
MM_LOW_CONFIDENCE_THRESHOLD=0.65
MM_LOW_CONFIDENCE_RETRY=1
# 以下模型直接透传，不做桥接（支持 * 通配符）
MM_PASS_THROUGH_MODELS=qwen3-vl-*,*vision*,*vl*,tstars2.0
